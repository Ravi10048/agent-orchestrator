# ─── LLM ────────────────────────────────────────────────────────────────
# Default provider; Groq is free + fast. Get a key at https://console.groq.com
DEFAULT_LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
# Optional fallback provider name (e.g. gemini); blank = no fallback
LLM_FALLBACK_PROVIDER=

# ─── Channel (Telegram) ─────────────────────────────────────────────────
# Free bot token from @BotFather. Blank = channel disabled (UI still works).
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_TIMEOUT=30

# ─── Persistence ────────────────────────────────────────────────────────
# SQLite by default; swap to Postgres by changing this URL only.
DATABASE_URL=sqlite:///./data/app.db

# ─── Scheduler ──────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MISFIRE_GRACE=3600

# ─── Executor / runtime guardrails ──────────────────────────────────────
MAX_RUN_STEPS=50
DEFAULT_MAX_VISITS=8
RUN_TIMEOUT_S=300
WS_BACKFILL_LIMIT=500

# ─── App ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
